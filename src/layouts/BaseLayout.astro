---
import '../styles/global.css';
import Analytics from '../components/Analytics.astro';
import { categories } from '../data/tools';
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><link rel="icon" type="image/svg+xml" href="/favicon.svg" /><Analytics /><slot name="head" /></head>
<body class="min-h-screen flex flex-col bg-gray-50">
  <header class="bg-gray-900 border-b border-gray-800 sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-9 h-9 bg-emerald-800 rounded-xl flex items-center justify-center text-orange-400 font-bold text-sm shadow-sm">{}</div>
        <span class="font-semibold text-white text-lg hidden sm:block">FreeToolkit <span class="text-orange-400">JSON</span></span>
      </a>
      <nav class="flex items-center gap-1 text-sm">
        <a href="/" class={`px-3 py-2 rounded-lg transition-colors ${currentPath === '/' ? 'bg-emerald-800 text-emerald-200 font-medium' : 'text-gray-400 hover:text-white'}`}>All Tools</a>
        <a href="/blog/" class={`px-3 py-2 rounded-lg transition-colors ${currentPath.startsWith('/blog') ? 'bg-emerald-800 text-emerald-200 font-medium' : 'text-gray-400 hover:text-white'}`}>Blog</a>
        <a href="/about/" class={`px-3 py-2 rounded-lg transition-colors ${currentPath === '/about/' ? 'bg-emerald-800 text-emerald-200 font-medium' : 'text-gray-400 hover:text-white'}`}>About</a>
        <a href="/contact/" class={`px-3 py-2 rounded-lg transition-colors ${currentPath === '/contact/' ? 'bg-emerald-800 text-emerald-200 font-medium' : 'text-gray-400 hover:text-white'}`}>Contact</a>
      </nav>
    </div>
  </header>
  <main class="flex-1"><slot /></main>
  <footer class="bg-gray-900 border-t border-gray-800 mt-16">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <div class="grid md:grid-cols-4 gap-8">
        <div><div class="flex items-center gap-2 mb-3"><div class="w-8 h-8 bg-emerald-800 rounded-lg flex items-center justify-center text-orange-400 font-bold text-xs">{}</div><span class="font-semibold text-white">FreeToolkit JSON</span></div><p class="text-sm text-gray-500">Free JSON and developer tools. Format, validate, convert, encode, and test code in your browser.</p></div>
        <div><h4 class="font-semibold text-white mb-3 text-sm">Categories</h4><ul class="space-y-2">{categories.map(cat => (<li><a href={`/#${cat.id}`} class="text-sm text-gray-500 hover:text-orange-400">{cat.icon} {cat.name}</a></li>))}</ul></div>
        <div><h4 class="font-semibold text-white mb-3 text-sm">Popular Tools</h4><ul class="space-y-2"><li><a href="/json-formatter/" class="text-sm text-gray-500 hover:text-orange-400">JSON Formatter</a></li><li><a href="/jwt-decoder/" class="text-sm text-gray-500 hover:text-orange-400">JWT Decoder</a></li><li><a href="/regex-tester/" class="text-sm text-gray-500 hover:text-orange-400">Regex Tester</a></li><li><a href="/base64/" class="text-sm text-gray-500 hover:text-orange-400">Base64</a></li></ul></div>
        <div><h4 class="font-semibold text-white mb-3 text-sm">Legal</h4><ul class="space-y-2"><li><a href="/about/" class="text-sm text-gray-500 hover:text-orange-400">About</a></li><li><a href="/contact/" class="text-sm text-gray-500 hover:text-orange-400">Contact</a></li><li><a href="/privacy/" class="text-sm text-gray-500 hover:text-orange-400">Privacy</a></li></ul></div>
      </div>
      <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm text-gray-600">&copy; {new Date().getFullYear()} FreeToolkit. All rights reserved.</div>
    </div>
  </footer>
</body></html>
