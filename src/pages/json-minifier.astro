---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import AdSense from '../components/AdSense.astro';
import JsonMinifier from '../components/tools/JsonMinifier';
---
<BaseLayout>
  <SEO slot="head" title="JSON Minifier" description="Minify JSON by removing whitespace." />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-6"><a href="/" class="hover:text-primary-600">Home</a> <span class="mx-2">›</span> <span class="text-gray-900">JSON Minifier</span></nav>
    <h1 class="text-3xl font-bold text-gray-900 mb-6">JSON Minifier</h1>
    <JsonMinifier client:load />
    <AdSense slot="bottom" />
  </div>
</BaseLayout>